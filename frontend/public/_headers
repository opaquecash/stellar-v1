# Security headers (#116).
#
# Picked up by Cloudflare Pages, Netlify, and any static host that
# honours the `_headers` convention. For Vercel deployments see
# `frontend/vercel.json` which mirrors the same policy.
#
# Policy rationale:
#   - CSP blocks inline scripts (except where Vite needs them for
#     dev — production builds emit hashed scripts only).
#   - WASM is required for snarkjs + opaque-scanner; the explicit
#     wasm-unsafe-eval keeps it working without widening the whole
#     script policy.
#   - frame-ancestors 'none' prevents clickjacking; we are not
#     embedded anywhere.
#   - Referrer-Policy strict-origin-when-cross-origin avoids leaking
#     full URLs to upstream Stellar APIs.
#   - Permissions-Policy denies every powerful API we don't need —
#     no camera, no microphone, no geolocation.

/*
  # Content Security Policy
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob:; connect-src 'self' https://horizon.stellar.org https://horizon-testnet.stellar.org https://soroban-rpc.stellar.org https://soroban-testnet.stellar.org wss:; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=(), payment=(), usb=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# WASM bundles require their MIME type set explicitly so streaming
# instantiation works on Safari + older Chrome.
/*.wasm
  Content-Type: application/wasm
  Cache-Control: public, max-age=31536000, immutable
